-- Create table
CREATE TABLE products (
    product_id INT PRIMARY KEY,
    product_name VARCHAR(100),
    price FLOAT,
    stock INT
);

-- Insert data
INSERT INTO products VALUES
(1, 'Laptop', 1200.50, 10),
(2, 'Phone', 800.00, 25),
(3, 'Headphones', 150.75, 50),
(4, 'Keyboard', 60.00, 40),
(5, 'Mouse', 30.50, 60);

-- View all data
SELECT * FROM products;

-- Filter data
SELECT * FROM products
WHERE price > 100;

-- Sort data
SELECT * FROM products
ORDER BY price DESC;

-- Delete a record
DELETE FROM products
WHERE product_id = 5;

-- Check table structure
DESCRIBE products;

-- Rename column
ALTER TABLE products
RENAME COLUMN product_name TO product_title;
